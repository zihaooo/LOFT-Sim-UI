{
  "name": "loft-sim-ui",
  "version": "0.9.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "mock:data": "python3 scripts/gen_mock_data.py --network public/data/network/airspace_network.osm --output mock/mock_telemetry.json --drones 1000",
    "mock:ws": "node scripts/mock_ws_server.mjs --data mock/mock_telemetry.json --hz 60",
    "verify:render": "node scripts/verify-render.mjs",
    "perf": "node scripts/perf/perf-bench.mjs",
    "perf:record": "node scripts/perf/perf-bench.mjs --record"
  },
  "dependencies": {
    "stats.js": "^0.17.0",
    "three": "^0.180.0",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.10",
    "tweakpane": "^4.0.5",
    "tweakpane-plugin-file-import": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.184.0",
    "puppeteer-core": "^25.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
