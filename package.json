{
  "name": "loft-sim-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "mock:data": "python3 scripts/gen_mock_data.py --route public/data/map/air_route.osm --output mock/mock_telemetry.json --drones 1000",
    "mock:ws": "node scripts/mock_ws_server.mjs --data mock/mock_telemetry.json --hz 60"
  },
  "dependencies": {
    "stats.js": "^0.17.0",
    "three": "^0.180.0",
    "tweakpane": "^4.0.5",
    "tweakpane-plugin-file-import": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
